{
  "name": "ProductiveWeb",
  "description": "",
  "version": "1.0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "/popup/popup.html"
  },
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["/scripts/youtube.js"],
      "run_at": "document_start"
    }
  ]
}
